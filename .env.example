PORT=8080
HOST=0.0.0.0

# Google AI Studio (Gemini) - preferred if available
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_FALLBACK_MODELS=gemini-flash-lite-latest,gemini-2.5-flash-lite,gemini-3-flash-preview

# Hugging Face Inference API
HF_API_TOKEN=hf_your_token_here
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_MAX_NEW_TOKENS=220
HF_TEMPERATURE=0.4
HF_TIMEOUT_MS=18000

# Optional fallback provider for Next.js route
OPENAI_API_KEY=

# Optional metadata used in responses
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/igiraneza-dominique-73229b2aa
CV_FILE_PATH=www/Dominique CV.pdf
